{
  "entities": {
    "Stats": {
      "title": "Stats",
      "description": "General statistics of the YouTube channel and local active members count.",
      "type": "object",
      "properties": {
        "subscriberCount": { "type": "number", "description": "Total subscriber count of the channel" },
        "subscriberGoal": { "type": "number", "description": "Goal count of subscribers to achieve" },
        "activeMembers": { "type": "number", "description": "Count of registered community members" },
        "totalViews": { "type": "number", "description": "Total views across all content" }
      },
      "required": ["subscriberCount", "subscriberGoal", "activeMembers", "totalViews"]
    },
    "User": {
      "title": "User",
      "description": "A user or seeker profile registered in the Stoic Oasis.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique user ID" },
        "username": { "type": "string", "description": "Human-readable display name" },
        "handle": { "type": "string", "description": "Unique lowercase stoic alpha-numeric handle" },
        "role": { "type": "string", "enum": ["admin", "member"], "description": "The authorization role of the user" },
        "avatarUrl": { "type": "string", "description": "Image URL of the user's avatar" },
        "joinedAt": { "type": "string", "format": "date-time", "description": "ISO timestamp of when the user registered" },
        "passwordHash": { "type": "string", "description": "Bcrypt hashed password for secure standard login" },
        "email": { "type": "string", "description": "The user's contact email address" }
      },
      "required": ["id", "username", "handle", "role", "avatarUrl", "joinedAt", "passwordHash"]
    },
    "Video": {
      "title": "Video",
      "description": "A YouTube video or Short synchronized from the channel or manually added.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique dynamic video identifier" },
        "ytId": { "type": "string", "description": "The actual YouTube video alphanumeric ID" },
        "title": { "type": "string", "description": "The parsed video caption title" },
        "description": { "type": "string", "description": "The full description body of the release" },
        "thumbnail": { "type": "string", "description": "Cover thumbnail capture URL" },
        "duration": { "type": "string", "description": "Duration formatted as MM:SS or HH:MM:SS" },
        "type": { "type": "string", "enum": ["long", "short"], "description": "Whether it is a full video or a Short" },
        "views": { "type": "number", "description": "Total accumulated view count" },
        "publishedAt": { "type": "string", "description": "Human readable publish date string" },
        "likes": { "type": "number", "description": "Total positive votes on the release" },
        "comments": { "type": "number", "description": "Proportional comment counts" },
        "category": { "type": "string", "description": "The high level niche category" },
        "subNiche": { "type": "string", "description": "The nested sub-topic focus" }
      },
      "required": ["id", "title", "description", "thumbnail", "duration", "type", "views", "publishedAt", "likes", "comments"]
    },
    "RoadmapItem": {
      "title": "RoadmapItem",
      "description": "A scheduled upcoming video release item in development.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique roadmap action ID" },
        "title": { "type": "string", "description": "Proposed topic or title of the guide" },
        "description": { "type": "string", "description": "Outline of key ideas to be covered" },
        "status": { "type": "string", "enum": ["scripting", "recording", "editing", "released"], "description": "Current pipeline status" },
        "type": { "type": "string", "enum": ["long", "short"], "description": "Release format of the item" },
        "publishDate": { "type": "string", "description": "Proposed target publication date" },
        "progress": { "type": "number", "description": "Development completion percentage (DCP)" },
        "likes": { "type": "array", "description": "List of user IDs who voted/upvoted this roadmap topic" }
      },
      "required": ["id", "title", "status", "type", "publishDate", "progress", "likes"]
    },
    "ForumPost": {
      "title": "ForumPost",
      "description": "An interactive post or topic started in the community forum.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique post ID" },
        "authorId": { "type": "string", "description": "The UID of the post author" },
        "authorName": { "type": "string", "description": "Name of the post creator" },
        "authorHandle": { "type": "string", "description": "Stoic handle of the author" },
        "authorAvatarUrl": { "type": "string", "description": "Avatar of the author" },
        "title": { "type": "string", "description": "The topic heading of the forum thread" },
        "content": { "type": "string", "description": "The full body question or markdown content of the thread" },
        "category": { "type": "string", "enum": ["mindset", "trends", "mysteries", "general"], "description": "Forum category group link" },
        "likes": { "type": "array", "description": "Collection of user UIDs who high-vibe liked this thread" },
        "commentsCount": { "type": "number", "description": "The running tally of replies" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO launch timestamp" }
      },
      "required": ["id", "authorId", "authorName", "authorHandle", "authorAvatarUrl", "title", "content", "category", "likes", "commentsCount", "createdAt"]
    },
    "ForumComment": {
      "title": "ForumComment",
      "description": "A focused response to a forum thread.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique comment identifier" },
        "postId": { "type": "string", "description": "The associated parent post ID" },
        "authorId": { "type": "string", "description": "UID of the commenter" },
        "authorName": { "type": "string", "description": "Username of the author" },
        "authorHandle": { "type": "string", "description": "Stoic handle of the author" },
        "authorAvatarUrl": { "type": "string", "description": "Avatar image source" },
        "content": { "type": "string", "description": "The body text comment message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO timestamp" }
      },
      "required": ["id", "postId", "authorId", "authorName", "authorHandle", "authorAvatarUrl", "content", "createdAt"]
    },
    "FanArt": {
      "title": "FanArt",
      "description": "User shared illustrations, thumbnails, and digital paintings.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique artwork ID" },
        "title": { "type": "string", "description": "Visual title of the illustration" },
        "description": { "type": "string", "description": "Aesthetic explanation or prompt description" },
        "url": { "type": "string", "description": "Direct image URL (can be Unsplash or local base64 payload)" },
        "isUploaded": { "type": "boolean", "description": "Whether the artwork has a raw uploaded payload" },
        "authorId": { "type": "string", "description": "UID of the contributor" },
        "authorName": { "type": "string", "description": "Display name of the contributor" },
        "authorHandle": { "type": "string", "description": "Stoic handle of the contributor" },
        "likes": { "type": "array", "description": "List of user UIDs who liked the artwork" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO upload timestamp" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Administration moderation status" }
      },
      "required": ["id", "title", "description", "url", "isUploaded", "authorId", "authorName", "authorHandle", "likes", "createdAt", "status"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message sent in the public room or direct 1-on-1 dialog with the channel AI Oracle.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Message unique reference" },
        "authorId": { "type": "string", "description": "The sender UID" },
        "authorName": { "type": "string", "description": "Sender user profile display name" },
        "authorAvatarUrl": { "type": "string", "description": "Sender avatar picture" },
        "authorRole": { "type": "string", "description": "User role: member or admin" },
        "content": { "type": "string", "description": "Visual message text payload" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO timestamp of the exchange" },
        "recipientId": { "type": "string", "description": "Recipient UID (e.g., 'admin' for AI Oracle, or null for public room chat)" }
      },
      "required": ["id", "authorId", "authorName", "authorAvatarUrl", "authorRole", "content", "createdAt"]
    },
    "BrandConfig": {
      "title": "BrandConfig",
      "description": "Theme tuning and customized channel profiles.",
      "type": "object",
      "properties": {
        "brandName": { "type": "string" },
        "brandHandle": { "type": "string" },
        "brandEmail": { "type": "string" },
        "logoType": { "type": "string" },
        "logoValue": { "type": "string" },
        "adminAvatarUrl": { "type": "string" },
        "announcement": { "type": "string" },
        "themeColor": { "type": "string" },
        "enableFanArtAutoApprove": { "type": "boolean" },
        "enableSlowModeForForum": { "type": "boolean" },
        "channelLink": { "type": "string" }
      }
    },
    "YoutubeConfig": {
      "title": "YoutubeConfig",
      "description": "Sync rates and channel definitions.",
      "type": "object",
      "properties": {
        "handle": { "type": "string" },
        "channelId": { "type": "string" },
        "enabled": { "type": "boolean" },
        "lastSyncedAt": { "type": "string", "format": "date-time" },
        "autoSyncIntervalMinutes": { "type": "number" },
        "syncLogs": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/stats/general": {
      "schema": "Stats",
      "description": "Singleton storing aggregate channel subscribers and views metrics"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Secure record of every registered Seeker using our system"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "List of YouTube videos categorized dynamically into full videos and Shorts"
    },
    "/roadmap/{roadId}": {
      "schema": "RoadmapItem",
      "description": "Interactive content pipeline roadmap items"
    },
    "/forumPosts/{postId}": {
      "schema": "ForumPost",
      "description": "Stoic discussion feed in the community hub"
    },
    "/forumComments/{commentId}": {
      "schema": "ForumComment",
      "description": "Responses and analytical comment trees connected to posts"
    },
    "/fanArt/{artId}": {
      "schema": "FanArt",
      "description": "Shared modern artwork submitted to Zen community"
    },
    "/chatMessages/{msgId}": {
      "schema": "ChatMessage",
      "description": "System-wide chats (both public chat room and direct Stoic Oracle messages)"
    },
    "/configs/brand": {
      "schema": "BrandConfig",
      "description": "Channel identity and custom palette preferences"
    },
    "/configs/youtube": {
      "schema": "YoutubeConfig",
      "description": "Sync frequencies, access indices and YouTube sync logs"
    }
  }
}
