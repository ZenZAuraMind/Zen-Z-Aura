rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions

    // Verify if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Verify user ID matches active authentication ID
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verify if the incoming document ID is valid (safeguard against injection)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Get the incoming document data
    function incoming() {
      return request.resource.data;
    }

    // Get the existing document data
    function existing() {
      return resource.data;
    }

    // Explicitly verify admin privileges by reading secure admin document node
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Catch-all safety gate (Default Close)
    match /{document=**} {
      allow read, write: if false;
    }

    // STATS Collection
    // Singleton for subscriber counters and channel metrics
    match /stats/{statId} {
      allow read: if true;
      // Allow incrementing statistics by verified admins, or allow visitors to hit subscribe post-increment tracker
      allow write: if isAdmin() || (statId == "general" && isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['subscriberCount', 'totalViews']));
    }

    // USERS Profiles Collection
    match /users/{userId} {
      // Users can retrieve their own private profile; administrators can retrieve any profile for roster lists.
      allow read: if isOwner(userId) || isAdmin();
      
      // Permit creation of profiles on signup
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    incoming().role == "member" && // Forbid self-promoting to admin on signup
                    incoming().username is string && incoming().username.size() <= 50;

      // Permit updating specific profile fields (e.g., changing display name/avatars) while keeping role/email locked.
      allow update: if isOwner(userId) && 
                    incoming().role == existing().role && // Prevent self-promoting role escalation
                    incoming().email == existing().email && // Keep email immutable through profile updates
                    incoming().joinedAt == existing().joinedAt && // Joined Date immutable
                    incoming().diff(existing()).affectedKeys().hasAny(['username', 'avatarUrl', 'passwordHash']);

      // Admin has complete management control over user profiles (including banning/promoting roles)
      allow delete: if isAdmin();
    }

    // VIDEOS Gallery Collection
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ROADMAP Collection
    match /roadmap/{roadId} {
      allow read: if true;
      allow write: if isAdmin();
      // Allow users to upvote or downvote roadmap item proposals (voting actions)
      allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes']);
    }

    // FORUM POSTS Collection
    match /forumPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(postId) && 
                    incoming().authorId == request.auth.uid && 
                    incoming().likes.size() == 0 && 
                    incoming().commentsCount == 0 && 
                    incoming().title is string && incoming().title.size() <= 150 && 
                    incoming().content is string && incoming().content.size() <= 5000;
      
      // Allow authors to update content, or allow signed-in users to only like posts
      allow update: if (isSignedIn() && existing().authorId == request.auth.uid && incoming().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['title', 'content'])) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) ||
                    isAdmin();
                    
      allow delete: if (isSignedIn() && existing().authorId == request.auth.uid) || isAdmin();
    }

    // FORUM COMMENTS Collection
    match /forumComments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(commentId) && 
                    incoming().authorId == request.auth.uid && 
                    incoming().content is string && incoming().content.size() <= 2000;
                    
      allow update: if (isSignedIn() && existing().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content'])) || isAdmin();
      allow delete: if (isSignedIn() && existing().authorId == request.auth.uid) || isAdmin();
    }

    // FAN ART Submissions Collection
    match /fanArt/{artId} {
      allow read: if true;
      
      allow create: if isSignedIn() && isValidId(artId) && 
                    incoming().authorId == request.auth.uid && 
                    incoming().title is string && incoming().title.size() <= 100 &&
                    incoming().url is string && incoming().url.size() <= 3000000; // supports base64 inside bounds
                    
      // Owner can update descriptive details, or admin changes approvals status, or any user reacts via likes
      allow update: if (isSignedIn() && existing().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['title', 'description'])) || 
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) || 
                    isAdmin();
                    
      allow delete: if (isSignedIn() && existing().authorId == request.auth.uid) || isAdmin();
    }

    // CHAT MESSAGES Collection (Public messages + AI direct messages)
    match /chatMessages/{msgId} {
      // Authenticated users can retrieve messages in the public room (recipientId == null)
      // For private 1-on-1 direct messages, only the author, recipient, or admin can read
      allow read: if isSignedIn() && (
        existing().recipientId == null ||
        existing().authorId == request.auth.uid ||
        existing().recipientId == request.auth.uid ||
        isAdmin()
      );

      // Create new chat messages
      allow create: if isSignedIn() && isValidId(msgId) && 
                    incoming().authorId == request.auth.uid && 
                    incoming().content is string && incoming().content.size() <= 1000;

      allow update, delete: if isAdmin();
    }

    // CONFIGURATIONS Collection (Theme coloring & API settings log indexes)
    match /configs/{configId} {
      allow read: if configId == "brand" || isAdmin();
      allow write: if isAdmin();
    }
  }
}
